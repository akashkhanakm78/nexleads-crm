
// alawys use npx prisma db push 
// never use migrate dev  

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
  MARKETING_EXECUTIVE
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  VISIT
  TASK
  NOTE
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  companies     Company[]
  contacts      Contact[]
  leads         Lead[]
  activities    Activity[]
  tasks         Task[]
  meetings      Meeting[]
  documents     Document[]
  notifications Notification[]
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  password       String   @default("")
  role           Role     @default(VIEWER)
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation  Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  activities    Activity[]
  tasks         Task[]
  meetings      Meeting[]
  documents     Document[]
  notifications Notification[]
}

model Company {
  id             String   @id @default(uuid())
  name           String   @unique
  domain         String?
  industry       String?
  employeeCount  Int?
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
}

model Contact {
  id             String   @id @default(uuid())
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  status         String   @default("No action")
  remarks        String?
  companyId      String
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  leads        Lead[]
}

model Lead {
  id             String       @id @default(uuid())
  title          String
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  contactStatus  String?
  value          Float?
  companyId      String?
  contactId      String?
  organisationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company      Company?     @relation(fields: [companyId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  activities   Activity[]
  tasks        Task[]
  meetings     Meeting[]
  documents    Document[]
}

model Activity {
  id             String       @id @default(uuid())
  type           ActivityType
  content        String
  userId         String
  leadId         String
  organisationId String
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id])
  lead         Lead         @relation(fields: [leadId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Task {
  id             String   @id @default(uuid())
  title          String
  dueDate        DateTime
  isDone         Boolean  @default(false)
  userId         String
  leadId         String?
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  lead         Lead?        @relation(fields: [leadId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Meeting {
  id             String   @id @default(uuid())
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  leadId         String?
  userId         String
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Document {
  id             String   @id @default(uuid())
  fileName       String
  fileUrl        String
  fileSize       Int?
  leadId         String?
  userId         String
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String   @id @default(uuid())
  title          String
  message        String
  isRead         Boolean  @default(false)
  userId         String
  organisationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
}
